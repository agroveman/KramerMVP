// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  description String?

  employees   Employee[]
}

model Employee {
  id           Int        @id @default(autoincrement())
  externalId   String     @unique
  firstName    String
  lastName     String
  title        String
  level        String
  tenureMonths Int

  department   Department @relation(fields: [departmentId], references: [id])
  departmentId Int

  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  managerId    Int?
  reports      Employee[] @relation("EmployeeManager")

  meetings     MeetingAttendee[]
  workflowSteps WorkflowStep[]
}

model Meeting {
  id          Int                @id @default(autoincrement())
  startedAt   DateTime
  durationMin Int
  topic       String

  attendees   MeetingAttendee[]
}

model MeetingAttendee {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  meeting    Meeting  @relation(fields: [meetingId], references: [id])
  meetingId  Int
}

model Workflow {
  id          Int            @id @default(autoincrement())
  name        String
  type        WorkflowType
  description String?

  steps       WorkflowStep[]
}

model WorkflowStep {
  id          Int       @id @default(autoincrement())
  order       Int
  isEscalation Boolean  @default(false)

  workflow    Workflow  @relation(fields: [workflowId], references: [id])
  workflowId  Int

  approver    Employee  @relation(fields: [approverId], references: [id])
  approverId  Int
}

enum WorkflowType {
  BUDGET
  VENDOR_CONTRACT
  PRODUCTION_LAUNCH
}
